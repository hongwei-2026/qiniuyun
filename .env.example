# ============================================
# VoiceCanvas 配置文件
# 复制为 backend/.env 后填入你的 API Key
# cp .env.example backend/.env
# ============================================

# --- 服务 ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- DeepSeek（语音意图理解 / LLM）---
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 默认模式: v4-pro | flash | chat
# v4-pro = deepseek-v4-pro（深度推理，适合复杂九宫格指令）
# flash  = deepseek-chat（快速响应）
# chat   = deepseek-chat（通用对话）
DEEPSEEK_MODE=chat

# 仅 v4-pro 生效
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true

# --- MiniMax 生图 ---
# 获取地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_IMAGE_URL=https://api.minimaxi.com/v1/image_generation
MINIMAX_IMAGE_MODEL=image-01

# --- 豆包 Seedream 生图（火山引擎 Ark）---
# 获取地址: https://console.volcengine.com/ark
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128

# --- 豆包 Seed3D 图生3D ---
ARK_3D_MODEL=doubao-seed3d-2-0-260328

# --- 默认生图提供商: minimax | doubao ---
IMAGE_PROVIDER=minimax

# --- 讯飞极速语音转写（高精度 ASR）---
# 控制台: https://console.xfyun.cn/
XFYUN_APP_ID=your-app-id
XFYUN_API_KEY=your-api-key
XFYUN_API_SECRET=your-api-secret
XFYUN_LANGUAGE=zh_cn
XFYUN_ACCENT=mandarin
XFYUN_DOMAIN=pro_ost_ed
# ost=极速录音转写 | iat=语音听写流式（需单独开通）
XFYUN_ASR_PRODUCT=ost

# ASR 默认: browser | xfyun
ASR_PROVIDER=browser
